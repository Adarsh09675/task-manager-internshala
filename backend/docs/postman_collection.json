{
  "info": {
    "name": "Task Manager Internshala API",
    "_postman_id": "9c7f6d3f-4e0c-4ff5-8f3e-b6f7b5b9a111",
    "description": "Postman collection for auth, profile, task CRUD, and admin summary routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    { "name": "Health Check", "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/api/v1/health" } },
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"user\"\n}" },
        "url": "{{baseUrl}}/api/v1/auth/register"
      }
    },
    {
      "name": "Register Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"admin\"\n}" },
        "url": "{{baseUrl}}/api/v1/auth/register"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secret123\"\n}" },
        "url": "{{baseUrl}}/api/v1/auth/login"
      }
    },
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/auth/me"
      }
    },
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Build assignment\",\n  \"description\": \"Create backend and frontend demo\",\n  \"status\": \"pending\",\n  \"priority\": \"high\"\n}" },
        "url": "{{baseUrl}}/api/v1/tasks"
      }
    },
    {
      "name": "Get All Tasks",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/tasks"
      }
    },
    {
      "name": "Get Task By Id",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}"
      }
    },
    {
      "name": "Update Task",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Build assignment updated\",\n  \"status\": \"completed\"\n}" },
        "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}"
      }
    },
    {
      "name": "Delete Task",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/tasks/{{taskId}}"
      }
    },
    {
      "name": "Admin Summary",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/api/v1/tasks/admin/summary"
      }
    }
  ]
}
